<script>
  function showSection(id) {
    const secs = ['pollo','combos','complementos','bebidas','postres'];
    secs.forEach(s => {
      document.getElementById('sec-' + s).style.display = (s === id) ? 'block' : 'none';
    });
    document.querySelectorAll('.cat-btn').forEach((btn, i) => {
      btn.classList.toggle('active', secs[i] === id);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
